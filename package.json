{
  "name": "price-finder",
  "version": "1.0.0",
  "description": "A smart product comparison platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "server": "nodemon server.js",
    "client": "cd client && npm start",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "install-all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "nodemon": "^3.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "keywords": ["ecommerce", "price-comparison", "react", "express"],
  "author": "Price Finder Team",
  "license": "MIT"
}
